generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  MANAGER
  EDITOR
}

enum RestaurantStatus {
  OPEN
  CLOSED
  TEMPORARILY_UNAVAILABLE
}

enum PricingType {
  FIXED
  VARIANTS
}

model User {
  id                 String     @id @default(cuid())
  email              String     @unique
  passwordHash       String
  role               Role       @default(OWNER)
  mustChangePassword Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  auditLogs          AuditLog[]
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  sortOrder   Int        @default(0)
  active      Boolean    @default(true)
  published   Boolean    @default(false)
  deletedAt   DateTime?
  items       MenuItem[]
  subcategories Subcategory[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([published, active, deletedAt, sortOrder])
}

model Subcategory {
  id         String     @id @default(cuid())
  categoryId String
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String
  nameEn     String?
  sortOrder  Int        @default(0)
  items      MenuItem[]

  @@unique([categoryId, name])
  @@index([categoryId, sortOrder])
}

model MenuItem {
  id                   String        @id @default(cuid())
  categoryId           String
  category             Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategoryId        String?
  subcategory          Subcategory?  @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  name                 String
  description          String?
  fullIngredients      String[]
  preparationNotes     String?
  servingNotes         String?
  quantityLabel        String?
  pricingType          PricingType   @default(FIXED)
  price                Decimal?      @db.Decimal(10, 2)
  proteinType          String?
  proteinWeight        String?
  includesRegularFries Boolean       @default(false)
  imageUrl             String?
  imagePublicId        String?
  imageAlt             String?
  active               Boolean       @default(true)
  featured             Boolean       @default(false)
  published            Boolean       @default(false)
  sortOrder            Int           @default(0)
  deletedAt            DateTime?
  variants             ItemVariant[]
  addOns               AddOn[]
  choiceGroups         ChoiceGroup[]
  badges               Badge[]
  allergens            Allergen[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([categoryId, published, active, deletedAt, sortOrder])
}

model ItemVariant {
  id        String   @id @default(cuid())
  itemId    String
  item      MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name      String
  weight    String?
  price     Decimal  @db.Decimal(10, 2)
  sortOrder Int      @default(0)
  available Boolean  @default(true)

  @@unique([itemId, name])
  @@index([itemId, sortOrder])
}

model AddOn {
  id        String     @id @default(cuid())
  name      String
  nameEn    String?
  price     Decimal    @db.Decimal(10, 2)
  category  String
  available Boolean    @default(true)
  sortOrder Int        @default(0)
  deletedAt DateTime?
  items     MenuItem[]

  @@index([category, available, sortOrder])
  @@unique([name, category])
}

model ChoiceGroup {
  id         String         @id @default(cuid())
  itemId     String
  item       MenuItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name       String
  required   Boolean        @default(false)
  minChoices Int            @default(0)
  maxChoices Int            @default(1)
  sortOrder  Int            @default(0)
  options    ChoiceOption[]

  @@index([itemId, sortOrder])
}

model ChoiceOption {
  id        String      @id @default(cuid())
  groupId   String
  group     ChoiceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name      String
  price     Decimal     @default(0) @db.Decimal(10, 2)
  available Boolean     @default(true)
  sortOrder Int         @default(0)

  @@index([groupId, sortOrder])
}

model Badge {
  id    String     @id @default(cuid())
  name  String     @unique
  items MenuItem[]
}

model Allergen {
  id    String     @id @default(cuid())
  name  String     @unique
  items MenuItem[]
}

model RestaurantSettings {
  id            Int              @id @default(1)
  name          String           @default("كأنه بيت")
  nameEn        String           @default("k2nobeit")
  description   String           @default("أكل بيتي فلسطيني، معمول بمحبة")
  currency      String           @default("₪")
  status        RestaurantStatus @default(OPEN)
  closedMessage String           @default("الدار مسكّرة هالوقت… بنستناكم بموعدنا الجاي.")
  primaryColor  String           @default("#66704A")
  logoUrl       String?
  phone         String?
  address       String?
  publishedAt   DateTime?
  updatedAt     DateTime         @updatedAt
}

model AuditLog {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action         String
  entityType     String
  entityId       String?
  previousValues Json?
  newValues      Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
}
